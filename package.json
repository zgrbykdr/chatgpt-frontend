{
  "name": "heatpump-sim",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform desktop Amesim-style heat pump simulator",
  "main": "electron/main.ts",
  "scripts": {
    "dev": "concurrently \"npm:dev:electron\" \"npm:dev:vite\"",
    "dev:electron": "ts-node electron/main.ts",
    "dev:vite": "vite --host",
    "lint": "npm run lint:ts && npm run lint:py",
    "lint:ts": "eslint \"app/src/**/*.{ts,tsx}\"",
    "lint:py": "python tools/scripts/lint_py.py",
    "test": "npm run test:ui && npm run test:engine",
    "test:ui": "jest --config app/jest.config.cjs",
    "test:engine": "pytest server/engine/tests",
    "build": "vite build",
    "package": "electron-builder -c electron/builder-config.yml",
    "schema": "ts-node tools/scripts/generate_schemas.ts"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.1.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.8.10",
    "@types/react": "^18.2.33",
    "@types/react-dom": "^18.2.13",
    "concurrently": "^8.2.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "eslint": "^8.53.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.33.2",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.0.3",
    "tailwindcss": "^3.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "vite": "^4.4.9",
    "vitest": "^0.34.6"
  },
  "dependencies": {
    "@mantine/hooks": "^6.0.21",
    "@tanstack/react-query": "^4.36.1",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "d3-force": "^3.0.0",
    "immer": "^10.0.2",
    "lodash-es": "^4.17.21",
    "mobx": "^6.10.2",
    "mobx-react-lite": "^4.0.5",
    "nanoid": "^4.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.18.0",
    "zustand": "^4.4.2"
  }
}
