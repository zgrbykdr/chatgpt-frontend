{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Condition Pack",
  "type": "object",
  "required": ["conditions"],
  "properties": {
    "conditions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "modifiers"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "defaultDurationRounds": { "type": "number" },
          "summary": { "type": "string" },
          "modifiers": { "type": "array", "items": { "type": "object" } }
        }
      }
    }
  }
}
