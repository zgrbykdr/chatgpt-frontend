{
  "geometry": {
    "mode": "import",
    "file_path": "examples/channel_flow/geometry_points.csv",
    "scale": 1.0
  },
  "meshing": {
    "global_size": 0.1,
    "growth_rate": 1.2,
    "local_sizing_rules": [
      {
        "name": "inlet_refine",
        "target_entities": ["boundary"],
        "size": 0.06,
        "growth_rate": 1.1,
        "enabled": true
      }
    ]
  },
  "solver": {
    "time_mode": "steady",
    "solver_type": "SIMPLE"
  },
  "turbulence": {
    "model": "k_omega_sst"
  }
}
